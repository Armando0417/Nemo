# Windows deployment example:
# Set this to the real folder that contains your manga library.
CODEX_VAULT_LIBRARY_PATH=D:\Wandering_Sea\T7_Branch\Sarcophagus\CV_Tomb

# API server
CODEX_VAULT_BACKEND_HOST=0.0.0.0
CODEX_VAULT_BACKEND_PORT=6220
CODEX_VAULT_DEBUG=false

# SQLite database file for the backend
CODEX_VAULT_DB_PATH=codex_vault.db

# Frontend access configuration
CODEX_VAULT_FRONTEND_PORT=6221
# Add extra allowed origins here when you know the public URL or LAN IP.
# Example:
# CODEX_VAULT_FRONTEND_ORIGINS=http://192.168.1.50:6221,https://vault.example.com
CODEX_VAULT_FRONTEND_ORIGINS=
