# Copy this to relay.env and adjust it for your Copyparty instance.

RELAY_PROJECT_NAME=Relay
RELAY_COPYPARTY_BASE_URL=http://127.0.0.1:3923
RELAY_COPYPARTY_USERNAME=relay
RELAY_COPYPARTY_PASSWORD=change-me
RELAY_COPYPARTY_USERS=relay:change-me

# Set this to 1 if you want Nemo to auto-start Copyparty with the launch command below.
RELAY_COPYPARTY_AUTO_START=0

# Example:
# RELAY_COPYPARTY_LAUNCH_COMMAND=C:\path\to\your\approved-copyparty-wrapper.cmd
RELAY_COPYPARTY_LAUNCH_COMMAND=
RELAY_COPYPARTY_LAUNCH_CWD=C:\Users\arman\Documents\Projects\Nemo\TitanRelay

RELAY_INBOX_ROOT=/device-handoff
RELAY_DUMP_ROOT=/device-handoff-dump
