# Priestess alert subsystem settings.
# Copy this file to priestess.env and set the webhook URL.

PRIESTESS_SERVICE_NAME=Priestess
PRIESTESS_ENABLED=1

# Create this in Discord:
# Server Settings -> Integrations -> Webhooks -> New Webhook -> Copy Webhook URL
PRIESTESS_DISCORD_WEBHOOK_URL=
PRIESTESS_DISCORD_USERNAME=Priestess
# Optional role/user mention to force Discord push notifications.
# Role ID shorthand is accepted and becomes <@&ROLE_ID>.
PRIESTESS_DISCORD_MENTION=

# Relay send alerts.
PRIESTESS_RELAY_ALERTS_ENABLED=1

# Internal delivery queue size.
PRIESTESS_QUEUE_MAX_SIZE=256
